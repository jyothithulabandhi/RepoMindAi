# RepoMind AI Environment Configuration

# LLM Providers (at least one is required)
# Gemini API Key (Recommended)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Alternative)
OPENAI_API_KEY=your_openai_api_key_here

# LLM Model overrides (Optional)
# If your key doesn't support gemini-1.5-flash, you can specify gemini-2.5-flash or gemini-1.5-pro here
GEMINI_MODEL=gemini-1.5-flash
# GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# OpenAI overrides (Optional)
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Groq API Key (Alternative)
# GROQ_API_KEY=your_groq_api_key_here

# Groq overrides (Optional)
# GROQ_MODEL=llama-3.3-70b-versatile

# Server Port
PORT=8000

